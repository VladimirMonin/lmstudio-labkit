{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lmstudio-sdk-tokenizer-capture-set-v1",
  "title": "LM Studio SDK runtime tokenizer capture set",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "captures"],
  "properties": {
    "schema_version": {"const": "lmstudio-sdk-tokenizer-capture-set-v1"},
    "captures": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schema_version", "authority", "capture_id", "model_key", "instance_id",
          "instance_config", "instance_config_sha256", "plan_sha256",
          "preflight", "post_unload", "private_evidence_relative_path",
          "private_evidence_sha256", "rows", "evidence_sha256", "authority_signature"
        ],
        "properties": {
          "schema_version": {"const": "lmstudio-sdk-tokenizer-capture-v2"},
          "authority": {
            "type": "object",
            "additionalProperties": false,
            "required": ["package", "version", "identity_sha256", "signature_algorithm"],
            "properties": {
              "package": {"const": "lmstudio"},
              "version": {"const": "1.5.0"},
              "identity_sha256": {"$ref": "#/$defs/sha256"},
              "signature_algorithm": {"const": "hmac-sha256-v1"}
            }
          },
          "capture_id": {"$ref": "#/$defs/sha256"},
          "model_key": {
            "enum": [
              "google/gemma-4-e2b", "google/gemma-4-e4b",
              "google/gemma-4-12b-qat", "google/gemma-4-26b-a4b-qat"
            ]
          },
          "instance_id": {"type": "string", "minLength": 1},
          "instance_config": {"type": "object"},
          "instance_config_sha256": {"$ref": "#/$defs/sha256"},
          "plan_sha256": {"$ref": "#/$defs/sha256"},
          "preflight": {"$ref": "#/$defs/zeroSnapshot"},
          "post_unload": {"$ref": "#/$defs/zeroSnapshot"},
          "private_evidence_relative_path": {"type": "string", "pattern": "^captures/[0-9a-f]{64}\\.json$"},
          "private_evidence_sha256": {"$ref": "#/$defs/sha256"},
          "evidence_sha256": {"$ref": "#/$defs/sha256"},
          "authority_signature": {"$ref": "#/$defs/sha256"},
          "rows": {
            "type": "array",
            "minItems": 20,
            "maxItems": 20,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "request_id", "model_id", "request_sha256", "byte_length",
                "chat_sha256", "formatted_prompt_sha256", "token_ids_sha256",
                "exact_token_count", "output_token_reserve", "safety_margin",
                "effective_context", "admitted"
              ],
              "properties": {
                "request_id": {"type": "string", "pattern": "^request-[0-9]{2}-[0-9]{2}$"},
                "model_id": {"type": "string"},
                "request_sha256": {"$ref": "#/$defs/sha256"},
                "byte_length": {"type": "integer", "minimum": 1},
                "chat_sha256": {"$ref": "#/$defs/sha256"},
                "formatted_prompt_sha256": {"$ref": "#/$defs/sha256"},
                "token_ids_sha256": {"$ref": "#/$defs/sha256"},
                "exact_token_count": {"type": "integer", "minimum": 1},
                "output_token_reserve": {"enum": [512, 2048]},
                "safety_margin": {"const": 256},
                "effective_context": {"enum": [8192, 16384, 28672]},
                "admitted": {"const": true}
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "zeroSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["loaded_count", "instance_bindings_sha256", "response_sha256"],
      "properties": {
        "loaded_count": {"const": 0},
        "instance_bindings_sha256": {"$ref": "#/$defs/sha256"},
        "response_sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
