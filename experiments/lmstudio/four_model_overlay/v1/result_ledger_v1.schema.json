{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "four-model-result-ledger-v2",
  "title": "Immutable per-call sanitized result ledger row",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "call_id", "request_id", "cell_id", "cell_request_index", "request_sha256", "scorer_binding", "raw_relative_path", "raw_output_sha256", "raw_output_bytes", "response_envelope_relative_path", "response_envelope_sha256", "response_envelope_bytes", "finish_reason", "native_usage", "scorecard_sha256", "scorecard", "contamination", "call_provenance", "validated_trace_sha256"],
  "properties": {
    "schema_version": {"const": "four-model-result-ledger-v2"},
    "call_id": {"type": "string", "pattern": "^call-[0-9]{2}-[0-9]{2}$"},
    "request_id": {"type": "string", "pattern": "^request-[0-9]{2}-[0-9]{2}$"},
    "cell_id": {"type": "string", "pattern": "^overlay_[0-9]{3}$"},
    "cell_request_index": {"type": "integer", "minimum": 0, "maximum": 3},
    "request_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "scorer_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["view_label", "task_family", "task_binding_sha256", "prompt_sha256", "output_schema_version", "output_schema_sha256", "target_sha256", "rubric_version", "rubric_sha256", "scorer_sha256"],
      "properties": {
        "view_label": {"type": "string"},
        "task_family": {"enum": ["normalization", "structural_context_retention"]},
        "task_binding_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "prompt_sha256": {"type": ["string", "null"]},
        "output_schema_version": {"type": ["string", "null"]},
        "output_schema_sha256": {"type": ["string", "null"]},
        "target_sha256": {"type": ["string", "null"]},
        "rubric_version": {"type": "string"},
        "rubric_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "scorer_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "raw_relative_path": {"type": "string", "pattern": "^call-[0-9]{2}-[0-9]{2}\\.raw\\.txt$"},
    "raw_output_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "raw_output_bytes": {"type": "integer", "minimum": 0},
    "response_envelope_relative_path": {"type": "string", "pattern": "^call-[0-9]{2}-[0-9]{2}\\.response\\.json$"},
    "response_envelope_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "response_envelope_bytes": {"type": "integer", "minimum": 2},
    "finish_reason": {"type": ["string", "null"]},
    "native_usage": {},
    "scorecard_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "scorecard": {"type": "object"},
    "contamination": {
      "type": "object", "additionalProperties": false,
      "required": ["algorithm", "present", "forbidden", "exact_repeat_equal", "passed"],
      "properties": {
        "algorithm": {"const": "literal-sentinel-v1"},
        "present": {"type": "array", "items": {"type": "string"}},
        "forbidden": {"type": "array", "items": {"type": "string"}},
        "exact_repeat_equal": {"type": ["boolean", "null"]},
        "passed": {"type": "boolean"}
      }
    },
    "validated_trace_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "call_provenance": {
      "type": "object", "additionalProperties": false,
      "required": ["call_id", "instance_id", "load_event_id", "endpoint", "backend_version", "model_id", "model_revision", "parameters_sha256", "request_sha256", "started_at", "ended_at", "terminal_state", "worker_slot"],
      "properties": {
        "call_id": {"type": "string"}, "instance_id": {"type": "string"},
        "load_event_id": {"type": "string"}, "endpoint": {"const": "/api/v1/chat"},
        "backend_version": {"type": "string"}, "model_id": {"type": "string"},
        "model_revision": {"type": "string"},
        "parameters_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "request_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "started_at": {"type": ["number", "string"]}, "ended_at": {"type": ["number", "string"]},
        "terminal_state": {"const": "completed"}, "worker_slot": {"type": ["integer", "null"]}
      }
    }
  }
}