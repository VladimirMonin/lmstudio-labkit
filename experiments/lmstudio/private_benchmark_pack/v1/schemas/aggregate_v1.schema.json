{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Aggregate report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "view_count",
    "media_backed_views",
    "media_unresolved_views",
    "semantic_gold_approved",
    "reference_candidates",
    "unsupported_reference_candidates",
    "model_calls",
    "claims"
  ],
  "properties": {
    "schema_version": {
      "const": "aggregate-v1"
    },
    "view_count": {
      "const": 16
    },
    "media_backed_views": {
      "type": "integer",
      "minimum": 0
    },
    "media_unresolved_views": {
      "type": "integer",
      "minimum": 0
    },
    "semantic_gold_approved": {
      "type": "integer",
      "minimum": 0
    },
    "reference_candidates": {
      "type": "integer",
      "minimum": 0
    },
    "unsupported_reference_candidates": {
      "type": "integer",
      "minimum": 0
    },
    "model_calls": {
      "const": 0
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    }
  }
}
