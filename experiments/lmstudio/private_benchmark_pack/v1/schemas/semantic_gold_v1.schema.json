{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Semantic gold v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "view_label",
    "status",
    "review_basis",
    "normalized_text",
    "blocks",
    "preserved_placeholders",
    "uncertain_spans",
    "output_sha256"
  ],
  "properties": {
    "schema_version": {
      "const": "semantic-gold-v1"
    },
    "view_label": {
      "type": "string",
      "pattern": "^(?:M(?:0[1-9]|10|11)|V(?:10|20|30)|L02-(?:E|M|L))$"
    },
    "status": {
      "const": "approved"
    },
    "review_basis": {
      "const": "two_independent_manual_source_reviews"
    },
    "normalized_text": {
      "type": "string",
      "minLength": 1
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "block_index",
          "source_unit_start",
          "source_unit_end",
          "normalized_text"
        ],
        "properties": {
          "block_index": {
            "type": "integer",
            "minimum": 0
          },
          "source_unit_start": {
            "type": "integer",
            "minimum": 0
          },
          "source_unit_end": {
            "type": "integer",
            "minimum": 1
          },
          "normalized_text": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "preserved_placeholders": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(?:PERSON|CONTACT|ACCOUNT|LOCATION|ORG|PRODUCT|ENTITY|DATE|PATH|SECRET|RARE)_[0-9]{3}$"
      }
    },
    "uncertain_spans": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_unit_start",
          "source_unit_end",
          "category"
        ],
        "properties": {
          "source_unit_start": {
            "type": "integer",
            "minimum": 0
          },
          "source_unit_end": {
            "type": "integer",
            "minimum": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "unclear",
              "possible_omission",
              "possible_repetition",
              "possible_entity_issue"
            ]
          }
        }
      }
    },
    "output_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
