{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sanitized blocks v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "view_label",
    "blocks"
  ],
  "properties": {
    "schema_version": {
      "const": "sanitized-blocks-v1"
    },
    "view_label": {
      "type": "string",
      "pattern": "^(?:M(?:0[1-9]|10|11)|V(?:10|20|30)|L02-(?:E|M|L))$"
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "block_index",
          "source_unit_start",
          "source_unit_end",
          "raw_text",
          "reference_candidate_text"
        ],
        "properties": {
          "block_index": {
            "type": "integer",
            "minimum": 0
          },
          "source_unit_start": {
            "type": "integer",
            "minimum": 0
          },
          "source_unit_end": {
            "type": "integer",
            "minimum": 1
          },
          "raw_text": {
            "type": "string",
            "minLength": 1
          },
          "reference_candidate_text": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}
