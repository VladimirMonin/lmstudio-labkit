{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Semantic review v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_version",
    "review_method",
    "review_scope",
    "counts",
    "verdicts",
    "non_claims"
  ],
  "properties": {
    "schema_version": {
      "const": "semantic-review-v1"
    },
    "pack_version": {
      "const": "v1"
    },
    "review_method": {
      "const": "two_independent_manual_source_reviews_with_private_adjudication"
    },
    "review_scope": {
      "const": "normalized_and_block_expected_outputs"
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approved",
        "reference",
        "unsupported"
      ],
      "properties": {
        "approved": {
          "type": "integer",
          "minimum": 0
        },
        "reference": {
          "type": "integer",
          "minimum": 0
        },
        "unsupported": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "verdicts": {
      "type": "array",
      "minItems": 16,
      "maxItems": 16,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "view_label",
          "verdict",
          "reason"
        ],
        "properties": {
          "view_label": {
            "type": "string",
            "pattern": "^(?:M(?:0[1-9]|10|11)|V(?:10|20|30)|L02-(?:E|M|L))$"
          },
          "verdict": {
            "type": "string",
            "enum": [
              "approved",
              "reference",
              "unsupported"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    }
  }
}
