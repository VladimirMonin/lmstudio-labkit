  "classification": {
    "authority": "application",
    "immutable_input": "transcript_text",
    "algorithm": [
      "Preserve transcript_text exactly.",
      "Skip leading Unicode whitespace for trigger detection only.",
      "At the first non-whitespace character match ASCII MODEL case-insensitively.",
      "Allow optional horizontal whitespace before a required colon.",
      "Accept ASCII colon or full-width colon.",
      "Extract the original suffix after the delimiter and trim outer whitespace only."
    ],
    "accepted_examples_by_shape": [
      "MODEL:<content>",
      "model: <content>",
      "leading_whitespace + MoDeL + optional_horizontal_space + colon + content",
